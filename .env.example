# ─── Variables del BACKEND (Railway las inyecta en el servicio web) ──────────
# El frontend NO necesita variables: habla con el backend en el mismo origen.

# Conexión a la Postgres de Railway.
#  - En Railway (servicio web): referenciá la del Postgres → ${{Postgres.DATABASE_URL}}
#  - Para correr scripts desde tu máquina: usá la URL PÚBLICA (proxy.rlwy.net)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Secreto para firmar los JWT de sesión (poné algo largo y aleatorio).
JWT_SECRET=cambiame-por-algo-largo-y-aleatorio

# Sólo si la conexión exige SSL (proxy público de Railway puede pedirlo).
# PGSSL=true

# ─── Sólo para server/seed.mjs (crear las 2 cuentas) ─────────────────────────
ROMI_EMAIL=romi@ejemplo.com
ROMI_NOMBRE=Romi
ROMI_COLOR=#CE8A99
# ROMI_PASSWORD=   # si lo dejás vacío, el seed genera una y la imprime

ALAN_EMAIL=alan@ejemplo.com
ALAN_NOMBRE=Alan
ALAN_COLOR=#7FA08E
# ALAN_PASSWORD=
